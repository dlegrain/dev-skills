# ===========================================
# diederick-starter — Variables d'environnement
# ===========================================
# Copie ce fichier vers .env.local :
#   cp .env.example .env.local

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Google Gemini (IA principale) ---
GEMINI_API_KEY=AIza...

# --- OpenAI (embeddings uniquement) ---
OPENAI_API_KEY=sk-...

# --- Langfuse (observabilité LLM — optionnel) ---
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Google Sheets (si utilisé comme backend de données) ---
# GOOGLE_SHEET_ID=
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=

# --- ElevenLabs (si assistant vocal) ---
# ELEVENLABS_API_KEY=
# AGENT_ID=

# --- Application ---
# LOG_LEVEL=debug
# NODE_ENV=development
